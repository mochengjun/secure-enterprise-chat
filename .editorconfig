# EditorConfig - 跨编辑器/IDE的统一代码风格配置
# https://editorconfig.org

# 顶级EditorConfig文件
root = true

# 所有文件的默认配置
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# ==================== JavaScript/TypeScript ====================
[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

# ==================== Python ====================
[*.py]
indent_size = 4
max_line_length = 100

[*.pyi]
indent_size = 4

# ==================== Dart/Flutter ====================
[*.dart]
indent_size = 2
max_line_length = 80

# ==================== Java ====================
[*.java]
indent_size = 4

# ==================== Go ====================
[*.go]
indent_style = tab

# ==================== Web相关 ====================
[*.{html,css,scss,sass,less}]
indent_size = 2

[*.{vue,svelte}]
indent_size = 2

# ==================== 配置文件 ====================
[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.toml]
indent_size = 2

[*.ini]
indent_size = 4

# ==================== Markdown ====================
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ==================== 文档 ====================
[*.{txt,rtf}]
indent_size = 4

# ==================== Shell脚本 ====================
[*.sh]
indent_size = 2

# ==================== Makefile ====================
[Makefile]
indent_style = tab

# ==================== 特殊文件 ====================
[.gitignore]
indent_size = 4

[.gitattributes]
indent_size = 4

[Dockerfile]
indent_size = 4

[docker-compose.yml]
indent_size = 2

# ==================== 项目特定文件 ====================
[package.json]
indent_size = 2

[pubspec.yaml]
indent_size = 2

[requirements.txt]
indent_size = 4

[setup.py]
indent_size = 4
