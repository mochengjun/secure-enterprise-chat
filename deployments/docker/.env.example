# ============================================================
# Secure Enterprise Chat - Environment Configuration Template
# Copy this file to .env and configure for your environment
# ============================================================

# ============================================================
# Application
# ============================================================
APP_VERSION=1.0.0
SERVER_MODE=release  # debug, release, test

# ============================================================
# Ports
# ============================================================
HTTP_PORT=80
HTTPS_PORT=443
API_PORT=8081
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# PostgreSQL Database
# ============================================================
POSTGRES_DB=sec_chat
POSTGRES_USER=sec_chat
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_SSL_MODE=disable  # disable, require, verify-full
DATABASE_MAX_CONNECTIONS=100
DATABASE_MAX_IDLE_CONNECTIONS=10

# ============================================================
# Redis Cache
# ============================================================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
REDIS_DB=0

# ============================================================
# MinIO Object Storage (Optional)
# ============================================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD_HERE
MINIO_BUCKET=sec-chat-media

# ============================================================
# JWT Authentication
# ============================================================
# IMPORTANT: Generate a secure random string (at least 32 characters)
# Example: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_MUST_BE_AT_LEAST_32_CHARACTERS_LONG
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=168h  # 7 days

# ============================================================
# Security
# ============================================================
BCRYPT_COST=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ============================================================
# Server Timeouts
# ============================================================
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# ============================================================
# Media Upload
# ============================================================
UPLOAD_MAX_SIZE=104857600  # 100MB in bytes
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,video/mp4,audio/mpeg,application/pdf

# ============================================================
# Push Notifications - Firebase Cloud Messaging
# ============================================================
FCM_ENABLED=false
# FCM credentials file should be placed at ./keys/firebase.json

# ============================================================
# Push Notifications - Apple APNs
# ============================================================
APNS_ENABLED=false
# APNS key file should be placed at ./keys/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# ============================================================
# WebRTC / TURN Server
# ============================================================
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, text

# ============================================================
# Message Cleanup (Optional cleanup service)
# ============================================================
CLEANUP_INTERVAL=1h
MESSAGE_RETENTION_DAYS=30
